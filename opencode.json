{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "9router": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:20128/v1",
        "apiKey": "sk_9router"
      },
      "models": {
        "asdasd/claude-sonnet-4.6": {
          "name": "asdasd/claude-sonnet-4.6",
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "9router/asdasd/claude-sonnet-4.6",
  "agent": {
    "explorer": {
      "description": "Fast explorer subagent for codebase exploration",
      "mode": "subagent",
      "model": "9router/ag/claude-opus-4-6-thinking"
    }
  }
}
